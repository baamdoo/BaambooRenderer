#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_GOOGLE_include_directive : require

#define _CAMERA
#include "DescriptorCommon.hg"
#include "HelperFunctions.hg"
#include "TerrainCommon.hg"

#define TERRAIN_MAX_VERTS  256
#define TERRAIN_MAX_PRIMS  256
#define TERRAIN_MS_THREADS 128

layout(set = 1, binding = 1) readonly buffer PatchInstanceBuffer
{
    PatchInstance g_PatchInstances[];
};
layout(set = 1, binding = 2) uniform sampler2D g_Heightmap;


struct SurfaceVertex
{
    vec3 posWS;
    vec2 uv;
};

SurfaceVertex ComputeSurfaceVertex(uint gx, uint gz, PatchInstance pi)
{
    float patchOriginX = pi.patchOriginX;
    float patchOriginZ = pi.patchOriginZ;
    float patchSizeM   = pi.patchSizeMeter;
    uint  gridN        = pi.gridDim;
    float rStart       = GetLodRangeStart(pi.depth);
    float rEnd         = GetLodRangeEnd  (pi.depth);

    vec2 gFine   = vec2(gx, gz);
    vec2 xzWORLD = vec2(patchOriginX, patchOriginZ) + gFine * (patchSizeM / float(gridN - 1u));

    float vertexSpacing = patchSizeM / float(gridN - 1u);
    float mipFine       = log2(vertexSpacing / g_Terrain.WorldPerTexel);

    vec2  tFine   = (xzWORLD - vec2(g_Terrain.TerrainOriginX, g_Terrain.TerrainOriginZ)) / g_Terrain.TerrainSizeMeter;
    float h01Fine = textureLod(g_Heightmap, tFine, max(0.0, mipFine)).r;

    float distVIEW = distance(g_Camera.posWORLD, vec3(xzWORLD.x, g_Terrain.HeightMinMeter + h01Fine * g_Terrain.HeightRangeMeter, xzWORLD.y));
    float alpha    = saturate((distVIEW - rStart) / max((rEnd - rStart), EPSILON_MIN));

    ivec2 gSnapped = ivec2(gx, gz) & ~1;
    vec2  gMorphed = mix(gFine, vec2(gSnapped), alpha);
    float guMorphed = gMorphed.x / float(gridN - 1u);
    float gvMorphed = gMorphed.y / float(gridN - 1u);

    float xWORLD = patchOriginX + guMorphed * patchSizeM;
    float zWORLD = patchOriginZ + gvMorphed * patchSizeM;
    float tu = (xWORLD - g_Terrain.TerrainOriginX) / g_Terrain.TerrainSizeMeter;
    float tv = (zWORLD - g_Terrain.TerrainOriginZ) / g_Terrain.TerrainSizeMeter;

    float h01 = textureLod(g_Heightmap, vec2(tu, tv), max(0.0, mipFine + alpha)).r;
    vec3  posWS = vec3(xWORLD, h01 * g_Terrain.HeightRangeMeter + g_Terrain.HeightMinMeter, zWORLD);

    SurfaceVertex sv;
    sv.posWS    = posWS;
    sv.uv       = vec2(tu, tv);
    return sv;
}

uvec2 PerimGridCoord(uint s, uint gridN)
{
    uint P = gridN - 1u;
    if (s < P)  return uvec2(s, 0u);            // bottom edge  (+x)
    s -= P;
    if (s < P)  return uvec2(P, s);             // right  edge  (+z)
    s -= P;
    if (s < P)  return uvec2(P - s, P);         // top    edge  (-x)
    s -= P;
    return uvec2(0u, P - s);                    // left   edge  (-z)
}

float ComputeSkirtDepth(PatchInstance pi)
{
    float gap   = pi.patchSizeMeter / float(pi.gridDim - 1u);
    float slope = g_Terrain.HeightRangeMeter / g_Terrain.TerrainSizeMeter;
    return 1.0 * slope * gap;
}

layout(local_size_x = TERRAIN_MS_THREADS, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = TERRAIN_MAX_VERTS, max_primitives = TERRAIN_MAX_PRIMS) out;

layout(location = 0) perprimitiveEXT out uint v_DrawID[];

void main()
{
    PatchInstance pi = g_PatchInstances[gl_DrawID];

    uint gridN = pi.gridDim;
    uint P     = gridN - 1u;

    uint surfVerts  = gridN * gridN;
    uint surfPrims  = 2u * P * P;
    uint skirtVerts = 4u * P;
    uint skirtPrims = 8u * P;
    uint totalVerts = surfVerts + skirtVerts;
    uint totalPrims = surfPrims + skirtPrims;
    SetMeshOutputsEXT(totalVerts, totalPrims);

    float skirtDepth = ComputeSkirtDepth(pi);

    // --- Vertices: [0,surfVerts) surface grid, then [surfVerts,..) skirt ---
    for (uint v = gl_LocalInvocationID.x; v < totalVerts; v += TERRAIN_MS_THREADS)
    {
        if (v < surfVerts)
        {
            SurfaceVertex sv = ComputeSurfaceVertex(v % gridN, v / gridN, pi);
            gl_MeshVerticesEXT[v].gl_Position = g_Camera.mViewProj * vec4(sv.posWS, 1.0);
        }
        else
        {
            // Skirt vertex: same morphed surface sample as its edge vertex, pushed straight down.
            uint  s = v - surfVerts;
            uvec2 g = PerimGridCoord(s, gridN);

            SurfaceVertex sv = ComputeSurfaceVertex(g.x, g.y, pi);

            vec3 skirtPos = vec3(sv.posWS.x, sv.posWS.y - skirtDepth, sv.posWS.z);

            gl_MeshVerticesEXT[v].gl_Position = g_Camera.mViewProj * vec4(skirtPos, 1.0);
        }
    }

    // --- Primitives: [0,surfPrims) surface grid, then skirt quads ---
    for (uint p = gl_LocalInvocationID.x; p < totalPrims; p += TERRAIN_MS_THREADS)
    {
        v_DrawID[p] = uint(gl_DrawID);

        if (p < surfPrims)
        {
            uint cid = p / 2u;
            uint px  = cid % P;
            uint pz  = cid / P;
            if (p % 2u == 0u)
                gl_PrimitiveTriangleIndicesEXT[p] = uvec3(pz * gridN + px, pz * gridN + px + 1u, (pz + 1u) * gridN + px);
            else
                gl_PrimitiveTriangleIndicesEXT[p] = uvec3(pz * gridN + px + 1u, (pz + 1u) * gridN + px + 1u, (pz + 1u) * gridN + px);
        }
        else
        {
            // Skirt quad for perimeter segment [seg, seg+1): two surface edge
            // vertices + their two pushed-down skirt vertices.
            uint sp  = p - surfPrims;
            uint seg = sp / 2u;
            uint s0  = seg;
            uint s1  = (seg + 1u) % skirtVerts;

            uvec2 g0 = PerimGridCoord(s0, gridN);
            uvec2 g1 = PerimGridCoord(s1, gridN);
            uint  surf0  = g0.y * gridN + g0.x;
            uint  surf1  = g1.y * gridN + g1.x;
            uint  skirt0 = surfVerts + s0;
            uint  skirt1 = surfVerts + s1;

            if (sp % 2u == 0u)
                gl_PrimitiveTriangleIndicesEXT[p] = uvec3(surf0, surf1, skirt1);
            else
                gl_PrimitiveTriangleIndicesEXT[p] = uvec3(surf0, skirt1, skirt0);
        }
    }
}
