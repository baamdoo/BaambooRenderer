#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_GOOGLE_include_directive : require

#define _CAMERA
#include "DescriptorCommon.hg"
#include "VisibilityBuffer.hg"

layout(set = 1, binding = 0) readonly buffer VoxelChunkBuffer
{
    VoxelChunk g_VoxelChunks[];
};
layout(set = 1, binding = 1) readonly buffer VoxelVertexBuffer
{
    Vertex g_VoxelVertices[];
};
layout(set = 1, binding = 2) readonly buffer VoxelMeshletBuffer
{
    Meshlet g_VoxelMeshlets[];
};
layout(set = 1, binding = 3) readonly buffer VoxelMeshletVertexBuffer
{
    uint g_VoxelMeshletVertices[];
};
layout(set = 1, binding = 4) readonly buffer VoxelMeshletTriangleBuffer
{
    uint g_VoxelMeshletTriangles[];
};

layout(location = 0) out vec4 outPosCLIP_curr[];
layout(location = 1) out vec4 outPosCLIP_prev[];

layout(location = 6) perprimitiveEXT out uint outVisID0[];
layout(location = 7) perprimitiveEXT out uint outVisID1[];

// Lane 0 loads the per-meshlet offsets once into shared memory.
shared vec3 sh_OriginWS;
shared uint sh_VertexSlabBase;
shared uint sh_MvBase;
shared uint sh_MtBase;
shared uint sh_VertexCount;
shared uint sh_TriangleCount;

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 124) out;
void main()
{
    uint localMeshletIndex = gl_WorkGroupID.x;
    uint ti                = gl_LocalInvocationID.x;

    if (ti == 0)
    {
        VoxelChunk chunk   = g_VoxelChunks[gl_DrawID];
        Meshlet       meshlet = g_VoxelMeshlets[chunk.meshletOffset + localMeshletIndex];

        sh_OriginWS       = vec3(chunk.originX, chunk.originY, chunk.originZ);
        sh_VertexSlabBase = chunk.vertexOffset;
        sh_MvBase         = chunk.meshletVertexOffset + meshlet.vertexOffset;
        sh_MtBase         = chunk.meshletTriangleOffset + meshlet.triangleOffset;
        sh_VertexCount    = meshlet.vertexCount;
        sh_TriangleCount  = meshlet.triangleCount;
    }
    barrier();

    SetMeshOutputsEXT(sh_VertexCount, sh_TriangleCount);

    for (uint i = ti; i < sh_VertexCount; i += gl_WorkGroupSize.x)
    {
        uint vi = sh_VertexSlabBase + g_VoxelMeshletVertices[sh_MvBase + i];
        Vertex vertex = g_VoxelVertices[vi];

        vec3 posLS = vec3(vertex.posX, vertex.posY, vertex.posZ);
        vec4 posWS = vec4(sh_OriginWS + posLS, 1.0);

        gl_MeshVerticesEXT[i].gl_Position = g_Camera.mViewProj * posWS;
        outPosCLIP_curr[i]                = g_Camera.mViewProjUnjittered     * posWS;
        outPosCLIP_prev[i]                = g_Camera.mViewProjUnjitteredPrev * posWS;
    }

    barrier();

    for (uint i = ti; i < sh_TriangleCount; i += gl_WorkGroupSize.x)
    {
        uint tPacked3 = g_VoxelMeshletTriangles[sh_MtBase + i];
        uint t0 = tPacked3 & 0xFFu;
        uint t1 = (tPacked3 >> 8) & 0xFFu;
        uint t2 = (tPacked3 >> 16) & 0xFFu;

        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(t0, t1, t2);

        outVisID0[i] = PackVisID0Voxel(uint(gl_DrawID));
        outVisID1[i] = PackVisID1(localMeshletIndex, i);
    }
}
